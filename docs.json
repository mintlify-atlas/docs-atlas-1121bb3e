{
  "$schema": "https://mintlify.com/docs.json",
  "name": "Inquirer.js",
  "theme": "luma",
  "colors": {
    "primary": "#242b2c",
    "light": "#6a6a6d",
    "dark": "#ebeaea"
  },
  "favicon": "https://media.brand.dev/bbb21190-6987-4c67-9b0d-d149e82e27b6.png",
  "navbar": {
    "primary": {
      "type": "github",
      "href": "https://github.com/SBoudrias/Inquirer.js"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/SBoudrias/Inquirer.js"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get Started",
            "pages": ["introduction", "quickstart"]
          },
          {
            "group": "Built-in Prompts",
            "pages": [
              "prompts/input",
              "prompts/select",
              "prompts/checkbox",
              "prompts/confirm",
              "prompts/search",
              "prompts/password",
              "prompts/number",
              "prompts/editor",
              "prompts/expand",
              "prompts/rawlist"
            ]
          },
          {
            "group": "Guides",
            "pages": [
              "guides/advanced-usage",
              "guides/theming",
              "guides/internationalization",
              "guides/recipes"
            ]
          }
        ]
      },
      {
        "tab": "Custom Prompts",
        "groups": [
          {
            "group": "Core API",
            "pages": [
              "core/overview",
              "core/hooks",
              "core/key-utilities"
            ]
          },
          {
            "group": "Testing",
            "pages": [
              "testing/unit-testing",
              "testing/e2e-testing"
            ]
          }
        ]
      }
    ]
  }
}
